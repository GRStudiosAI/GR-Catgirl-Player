{
  "name": "gr-catgirl-player",
  "version": "1.0.1",
  "description": "GR Catgirl Player",
  "main": "electron/main.js",
  "scripts": {
    "start": "node server.js",
    "build": "echo 'No build step required'",
    "lint": "echo 'No lint required'",
    "electron:start": "electron .",
    "electron:pack": "electron-builder --dir",
    "electron:dist": "electron-builder",
    "build:win": "npm run build && electron-builder --win"
  },
  "dependencies": {
    "ffmpeg-static": "^5.2.0"
  },
  "devDependencies": {
    "electron": "^30.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.grcatgirl.player",
    "productName": "GR Catgirl Player",
    "directories": {
      "buildResources": "public"
	  "output": "release"
    },
    "files": [
      "index.html",
      "server.js",
      "js/**/*",
      "public/**/*",
      "assets/**/*",
      "electron/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "public/logos/logo.png"
    },
    "fileAssociations": [
      {
        "ext": ["gif", "png", "jpg", "jpeg", "webp", "svg"],
        "name": "Image File",
        "description": "Image File",
        "role": "Viewer"
      },
      {
        "ext": ["mp4", "mkv", "avi", "mov", "webm"],
        "name": "Video File",
        "description": "Video File",
        "role": "Viewer"
      },
      {
        "ext": ["mp3", "flac", "wav", "ogg", "m4a"],
        "name": "Audio File",
        "description": "Audio File",
        "role": "Viewer"
      }
    ]
  }
}

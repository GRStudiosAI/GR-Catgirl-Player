{
"name": "gr-catgirl-player",
"version": "1.0.0",
"description": "GR Catgirl Player",
"main": "electron/main.js",

"scripts": {
"start": "electron .",
"pack": "electron-builder --dir",
"dist": "electron-builder --win",
"build:win": "electron-builder --win"
},

"dependencies": {
"ffmpeg-static": "^5.2.0"
},

"devDependencies": {
"electron": "^30.0.0",
"electron-builder": "^24.13.3"
},

"build": {
"appId": "com.grcatgirl.player",
"productName": "GR Catgirl Player",


"directories": {
  "buildResources": "public",
  "output": "dist"
},

"files": [
  "**/*",
  "electron/**/*",
  "public/**/*",
  "*.html",
  "*.css",
  "*.js",
  "*.json"
],

"extraResources": [
  {
    "from": "public",
    "to": "public"
  }
],

"asar": true,

"win": {
  "target": [
    "nsis",
    "portable"
  ],
  "icon": "public/logos/favicon.ico"
},

"fileAssociations": [
  {
    "ext": [
      "gif",
      "png",
      "jpg",
      "jpeg",
      "webp",
      "svg"
    ],
    "name": "Image File",
    "description": "Image File",
    "role": "Viewer"
  },
  {
    "ext": [
      "mp4",
      "mkv",
      "avi",
      "mov",
      "webm"
    ],
    "name": "Video File",
    "description": "Video File",
    "role": "Viewer"
  },
  {
    "ext": [
      "mp3",
      "flac",
      "wav",
      "ogg",
      "m4a"
    ],
    "name": "Audio File",
    "description": "Audio File",
    "role": "Viewer"
  }
]


}
}
